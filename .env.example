# ──────────────────────────────────────────────────────────
# JoyVet Care — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────

# Django
SECRET_KEY=change-this-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=192.168.1.100,joyvet.local,localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=joyvet
DB_USER=joyvet
DB_PASSWORD=choose-a-strong-password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Clinic identity
CLINIC_NAME=JoyVet Care
INVOICE_PREFIX=INV

# WhatsApp (optional — leave blank to disable)
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+1415XXXXXXX

# Alternative: 360dialog
DIALOG360_API_KEY=

# Cloud backup (optional — leave blank to disable)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-southeast-1
